<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F0F7F0">

    <!-- Top Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="16dp"
        android:paddingBottom="16dp"
        android:gravity="center_vertical"
        android:background="#2E7D32">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/good_morning"
                android:textColor="#A5D6A7"
                android:textSize="13sp"/>

            <TextView
                android:id="@+id/tvUsername"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/inuli"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold"/>

        </LinearLayout>

        <!-- Sessions Badge -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginEnd="16dp">

            <TextView
                android:id="@+id/tvHomeSessionCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="sessions"
                android:textColor="#A5D6A7"
                android:textSize="10sp"/>

        </LinearLayout>

        <ImageView
            android:id="@+id/ivProfile"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:contentDescription="@string/todo1"
            android:src="@mipmap/ic_launcher_round"
            android:background="@drawable/circle_dark_green"/>

    </LinearLayout>

    <!-- Scrollable Content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="16dp"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Mood Question -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/how_are_you_feeling_today"
                android:textColor="#1B5E20"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginBottom="10dp"/>

            <!-- Emoji Mood Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/card_shadow"
                android:padding="14dp"
                android:layout_marginBottom="16dp">

                <TextView android:id="@+id/mood1"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:text="@string/emoji"
                    android:gravity="center"
                    android:textSize="26sp"/>

                <TextView android:id="@+id/mood2"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:text="@string/emoji1"
                    android:gravity="center"
                    android:textSize="26sp"/>

                <TextView android:id="@+id/mood3"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:text="@string/emoji2"
                    android:gravity="center"
                    android:textSize="26sp"/>

                <TextView android:id="@+id/mood4"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:text="@string/emoji3"
                    android:gravity="center"
                    android:textSize="26sp"/>

                <TextView android:id="@+id/mood5"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:text="@string/emoji4"
                    android:gravity="center"
                    android:textSize="26sp"/>

            </LinearLayout>

            <!-- Quick Access -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/quick_access"
                android:textColor="#1B5E20"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginBottom="10dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <Button
                    android:id="@+id/btnStartDrawing"
                    android:layout_width="0dp"
                    android:layout_height="90dp"
                    android:layout_weight="1"
                    android:text="@string/start_drawing"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#2E7D32"
                    android:layout_marginEnd="8dp"
                    android:textSize="13sp"
                    android:elevation="4dp"/>

                <Button
                    android:id="@+id/btnChatAI"
                    android:layout_width="0dp"
                    android:layout_height="90dp"
                    android:layout_weight="1"
                    android:text="@string/chat_with_ai"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#388E3C"
                    android:textSize="13sp"
                    android:elevation="4dp"/>

            </LinearLayout>

            <!-- Real Stats Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_shadow"
                android:padding="16dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Your Journey 🌿"
                    android:textColor="#1B5E20"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp"/>

                <!-- Stats Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="#E8F5E9"
                        android:padding="12dp"
                        android:layout_marginEnd="6dp">

                        <TextView
                            android:id="@+id/tvHomeEmotions"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="#2E7D32"
                            android:textSize="28sp"
                            android:textStyle="bold"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Sessions"
                            android:textColor="#4CAF50"
                            android:textSize="11sp"/>

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="#E8F5E9"
                        android:padding="12dp"
                        android:layout_marginEnd="6dp">

                        <TextView
                            android:id="@+id/tvHomeArtworks"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="#2E7D32"
                            android:textSize="28sp"
                            android:textStyle="bold"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Artworks"
                            android:textColor="#4CAF50"
                            android:textSize="11sp"/>

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="#E8F5E9"
                        android:padding="12dp">

                        <TextView
                            android:id="@+id/tvHomeStreak"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0🔥"
                            android:textColor="#2E7D32"
                            android:textSize="28sp"
                            android:textStyle="bold"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Streak"
                            android:textColor="#4CAF50"
                            android:textSize="11sp"/>

                    </LinearLayout>

                </LinearLayout>

                <!-- Latest Emotion Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="#F1F8F1"
                    android:padding="12dp">

                    <TextView
                        android:id="@+id/tvLatestEmoji"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🌱"
                        android:textSize="24sp"
                        android:layout_marginEnd="10dp"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Latest emotion"
                            android:textColor="#888888"
                            android:textSize="11sp"/>

                        <TextView
                            android:id="@+id/tvLatestEmotion"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="No sessions yet"
                            android:textColor="#1B5E20"
                            android:textSize="13sp"
                            android:textStyle="bold"/>

                    </LinearLayout>

                    <Button
                        android:id="@+id/btnViewProgress"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="View"
                        android:textColor="#FFFFFF"
                        android:backgroundTint="#2E7D32"
                        android:textSize="11sp"/>

                </LinearLayout>

            </LinearLayout>

            <!-- Tips Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:background="@drawable/card_shadow"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/tips_and_guides"
                    android:textColor="#1B5E20"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/try_drawing_how_you_feel_today_n_take_5_deep_breaths_n_express_yourself_freely_through_art"
                    android:textColor="#4CAF50"
                    android:textSize="12sp"
                    android:lineSpacingMultiplier="1.6"/>

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <include layout="@layout/bottom_nav"/>

</LinearLayout>