<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#E8F5E9">

    <!-- Top Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical"
        android:background="#2E7D32">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/good_morning"
                android:textColor="#A5D6A7"
                android:textSize="14sp"/>

            <TextView
                android:id="@+id/tvUsername"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/inuli"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold"/>

        </LinearLayout>

        <ImageView
            android:id="@+id/ivProfile"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:contentDescription="@string/todo1"
            android:src="@mipmap/ic_launcher_round"
            android:background="@drawable/circle_dark_green"/>

    </LinearLayout>

    <!-- Scrollable Content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Mood Question -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/how_are_you_feeling_today"
                android:textColor="#2E7D32"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"/>

            <!-- Emoji Mood Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/card_background"
                android:padding="12dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:id="@+id/mood1"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:text="@string/emoji"
                    android:gravity="center"
                    android:textSize="24sp"/>

                <TextView
                    android:id="@+id/mood2"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:text="@string/emoji1"
                    android:gravity="center"
                    android:textSize="24sp"/>

                <TextView
                    android:id="@+id/mood3"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:text="@string/emoji2"
                    android:gravity="center"
                    android:textSize="24sp"/>

                <TextView
                    android:id="@+id/mood4"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:text="@string/emoji3"
                    android:gravity="center"
                    android:textSize="24sp"/>

                <TextView
                    android:id="@+id/mood5"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:text="@string/emoji4"
                    android:gravity="center"
                    android:textSize="24sp"/>

            </LinearLayout>

            <!-- Quick Access Title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/quick_access"
                android:textColor="#2E7D32"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"/>

            <!-- Quick Access Buttons -->
            <LinearLayout
                style="?android:attr/buttonBarStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <Button
                    android:id="@+id/btnStartDrawing"
                    style="?android:attr/buttonBarButtonStyle"
                    android:layout_width="0dp"
                    android:layout_height="80dp"
                    android:layout_weight="1"
                    android:text="@string/start_drawing"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#2E7D32"
                    android:layout_marginEnd="8dp"
                    android:textSize="13sp" />

                <Button
                    android:id="@+id/btnChatAI"
                    style="?android:attr/buttonBarButtonStyle"
                    android:layout_width="0dp"
                    android:layout_height="80dp"
                    android:layout_weight="1"
                    android:text="@string/chat_with_ai"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#388E3C"
                    android:textSize="13sp"/>

            </LinearLayout>

            <!-- Mood Progress Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_background"
                android:padding="16dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/mood_progress"
                    android:textColor="#2E7D32"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/track_your_emotional_wellness_journey"
                    android:textColor="#4CAF50"
                    android:textSize="12sp"
                    android:layout_marginBottom="12dp"/>

                <!-- Progress Bar -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/this_week"
                    android:textColor="#2E7D32"
                    android:textSize="12sp"
                    android:layout_marginBottom="4dp"/>

                <ProgressBar
                    android:id="@+id/progressMood"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="12dp"
                    android:progress="70"
                    android:progressTint="#2E7D32"
                    android:progressBackgroundTint="#C8E6C9"
                    android:layout_marginBottom="8dp"/>

                <Button
                    android:id="@+id/btnViewProgress"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:text="@string/view_progress"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#2E7D32"
                    android:textSize="12sp"/>

            </LinearLayout>

            <!-- Tips Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:background="@drawable/card_background"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/tips_and_guides"
                    android:textColor="#2E7D32"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/try_drawing_how_you_feel_today_n_take_5_deep_breaths_n_express_yourself_freely_through_art"
                    android:textColor="#4CAF50"
                    android:textSize="12sp" />

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <include layout="@layout/bottom_nav"/>

</LinearLayout>