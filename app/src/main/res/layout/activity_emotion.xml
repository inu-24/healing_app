<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#E8F5E9">

    <!-- Top Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:background="#2E7D32"
        android:gravity="center_vertical"
        android:padding="12dp">

        <TextView
            android:id="@+id/btnBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/back_arrow"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:layout_marginEnd="12dp"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/emotion_analysis1"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/btnShare"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/share"
            android:textColor="#A5D6A7"
            android:textSize="14sp"/>

    </LinearLayout>

    <!-- Scrollable Content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <!-- Emotion Face Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/card_background"
                android:padding="32dp"
                android:layout_marginBottom="16dp">

                <!-- Sparkle top left -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/sparkles"
                    android:textSize="20sp"
                    android:gravity="start"
                    android:layout_marginBottom="8dp"/>

                <!-- Smiley Face -->
                <TextView
                    android:id="@+id/tvEmojiFace"
                    android:layout_width="120dp"
                    android:layout_height="120dp"
                    android:text="@string/happy1"
                    android:textSize="72sp"
                    android:gravity="center"
                    android:background="@drawable/circle_light_green"
                    android:layout_marginBottom="8dp"/>

                <!-- Sparkle bottom right -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/sparkle"
                    android:textSize="16sp"
                    android:gravity="end"
                    android:layout_marginTop="8dp"/>

                <!-- Emotion Result Text -->
                <TextView
                    android:id="@+id/tvEmotionResult"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/your_drawing_reflects_calmness_nwith_slight_stress_tones"
                    android:textColor="#1B5E20"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:layout_marginTop="16dp"/>

            </LinearLayout>

            <!-- Emotion Tags Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/calm2"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:background="#2E7D32"
                    android:padding="8dp"
                    android:layout_marginEnd="8dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/slight_stress"
                    android:textColor="#2E7D32"
                    android:textSize="12sp"
                    android:background="#FFFFFF"
                    android:padding="8dp"
                    android:layout_marginEnd="8dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/hopeful1"
                    android:textColor="#2E7D32"
                    android:textSize="12sp"
                    android:background="#FFFFFF"
                    android:padding="8dp"/>

            </LinearLayout>

            <!-- What This Means Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_background"
                android:padding="16dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/what_this_means"
                    android:textColor="#1B5E20"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:id="@+id/tvMeaning"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/you_may_be_experiencing_mild_stress_but_your_emotions_are_mostly_balanced_your_use_of_soft_colors_and_gentle_strokes_suggests_an_inner_calm_trying_to_surface"
                    android:textColor="#4CAF50"
                    android:textSize="13sp"
                    android:lineSpacingMultiplier="1.5"
                    android:layout_marginBottom="12dp"/>

                <!-- Emotion Level Bars -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/calm1"
                    android:textColor="#2E7D32"
                    android:textSize="12sp"
                    android:layout_marginBottom="4dp"/>

                <ProgressBar
                    android:layout_width="match_parent"
                    android:layout_height="8dp"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:progress="75"
                    android:progressTint="#2E7D32"
                    android:progressBackgroundTint="#C8E6C9"
                    android:layout_marginBottom="10dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/stress"
                    android:textColor="#2E7D32"
                    android:textSize="12sp"
                    android:layout_marginBottom="4dp"/>

                <ProgressBar
                    android:layout_width="match_parent"
                    android:layout_height="8dp"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:progress="25"
                    android:progressTint="#EF5350"
                    android:progressBackgroundTint="#C8E6C9"
                    android:layout_marginBottom="10dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/hopeful"
                    android:textColor="#2E7D32"
                    android:textSize="12sp"
                    android:layout_marginBottom="4dp"/>

                <ProgressBar
                    android:layout_width="match_parent"
                    android:layout_height="8dp"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:progress="60"
                    android:progressTint="#4CAF50"
                    android:progressBackgroundTint="#C8E6C9"
                    android:layout_marginBottom="4dp"/>

            </LinearLayout>

            <!-- Save to Progress Button -->
            <Button
                android:id="@+id/btnSaveProgress"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="@string/save_to_progress"
                android:textColor="#FFFFFF"
                android:backgroundTint="#2E7D32"
                android:textStyle="bold"
                android:layout_marginBottom="16dp"/>

            <!-- Draw Again Link -->
            <TextView
                android:id="@+id/tvDrawAgain"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/draw_again"
                android:textColor="#2E7D32"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="32dp"/>

        </LinearLayout>
    </ScrollView>

    <include layout="@layout/bottom_nav"/>
</LinearLayout>