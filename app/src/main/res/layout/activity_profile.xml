<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F7F9F7">

    <!-- Top Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical"
        android:background="#FFFFFF">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:contentDescription="@string/back6"
            android:src="@drawable/baseline_arrow_back_ios_24"
            android:layout_marginEnd="12dp"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/my_profile6"
            android:textColor="#1A1A1A"
            android:textSize="15sp"
            android:textStyle="bold"
            android:gravity="center"/>

        <ImageView
            android:id="@+id/btnSettings"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:contentDescription="@string/settings4"
            android:src="@drawable/baseline_settings_24"/>

    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="16dp">

            <!-- Profile Header Panel -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_header_panel"
                android:padding="28dp">

                <FrameLayout
                    android:layout_width="88dp"
                    android:layout_height="88dp">

                    <ImageView
                        android:layout_width="88dp"
                        android:layout_height="88dp"
                        android:background="@drawable/bg_avatar_ring"
                        android:padding="4dp"
                        android:contentDescription="@string/profile_photo_frame4"/>

                    <ImageView
                        android:id="@+id/ivProfilePhoto"
                        android:layout_width="76dp"
                        android:layout_height="76dp"
                        android:layout_gravity="center"
                        android:contentDescription="@string/profile_photo6"
                        android:src="@mipmap/ic_launcher_round"
                        android:background="@drawable/circle_light_green"
                        android:scaleType="centerCrop"
                        android:clipToOutline="true"/>

                </FrameLayout>

                <TextView
                    android:id="@+id/tvName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="#1A1A1A"
                    android:textSize="19sp"
                    android:textStyle="bold"
                    android:layout_marginTop="14dp"
                    tools:text="Ron"/>

                <TextView
                    android:id="@+id/tvJoinDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="#5C8A5F"
                    android:textSize="13sp"
                    android:layout_marginTop="2dp"
                    tools:text="Healing since Jan 2025"/>

                <Button
                    android:id="@+id/btnEditProfile"
                    android:layout_width="wrap_content"
                    android:layout_height="42dp"
                    android:text="@string/edit_profile6"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/bg_button_solid"
                    android:paddingStart="24dp"
                    android:paddingEnd="24dp"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textAllCaps="false"
                    android:elevation="0dp"
                    android:stateListAnimator="@null"
                    android:layout_marginTop="16dp"/>

            </LinearLayout>

            <!-- Mood Summary Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card_rounded"
                android:elevation="2dp"
                android:padding="18dp"
                android:layout_margin="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/mood_this_week4"
                    android:textColor="#1A1A1A"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="14dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:baselineAligned="false"
                    android:orientation="horizontal"
                    android:layout_marginBottom="16dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:background="@drawable/bg_stat_box"
                        android:padding="14dp"
                        android:layout_marginEnd="8dp">

                        <TextView
                            android:id="@+id/tvCheckInsCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/_05"
                            android:textColor="#1B5E20"
                            android:textSize="24sp"
                            android:textStyle="bold"
                            tools:text="12"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/check_ins_logged4"
                            android:textColor="#5C8A5F"
                            android:textSize="11sp"
                            android:layout_marginTop="2dp"/>

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:background="@drawable/bg_stat_box"
                        android:padding="14dp">

                        <TextView
                            android:id="@+id/tvGoodMoodDays"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/_04"
                            android:textColor="#1B5E20"
                            android:textSize="24sp"
                            android:textStyle="bold"
                            tools:text="7"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/good_mood_days3"
                            android:textColor="#5C8A5F"
                            android:textSize="11sp"
                            android:layout_marginTop="2dp"/>

                    </LinearLayout>

                </LinearLayout>

                <TextView
                    android:id="@+id/tvMostFrequentMood"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/most_frequent_mood2"
                    android:textColor="#888888"
                    android:textSize="11sp"
                    android:layout_marginBottom="8dp"
                    tools:text="Most frequent mood: Calm (70%)"/>

                <ProgressBar
                    android:id="@+id/progressMood"
                    android:layout_width="match_parent"
                    android:layout_height="14dp"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:progress="0"
                    android:progressDrawable="@drawable/progress_mood_rounded"/>

            </LinearLayout>

            <!-- Achievements Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card_rounded"
                android:elevation="2dp"
                android:padding="18dp"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/achievements4"
                    android:textColor="#1A1A1A"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="14dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:baselineAligned="false"
                    android:orientation="horizontal"
                    android:layout_marginBottom="10dp">

                    <!-- First Steps -->
                    <LinearLayout
                        android:id="@+id/badgeFirstSteps"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:background="@drawable/bg_badge_earned"
                        android:padding="14dp"
                        android:layout_marginEnd="8dp">

                        <FrameLayout
                            android:layout_width="38dp"
                            android:layout_height="38dp">
                            <ImageView
                                android:layout_width="38dp"
                                android:layout_height="38dp"
                                android:background="@drawable/bg_icon_chip"
                                android:contentDescription="@string/badge_icon_background4"/>
                            <TextView
                                android:layout_width="38dp"
                                android:layout_height="38dp"
                                android:text="@string/Tr"
                                android:textSize="18sp"
                                android:gravity="center"/>
                        </FrameLayout>

                        <TextView
                            android:id="@+id/tvFirstStepsTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/first_steps5"
                            android:textColor="#1B5E20"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:layout_marginTop="10dp"/>

                        <TextView
                            android:id="@+id/tvFirstStepsSubtitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/first_check_in3"
                            android:textColor="#5C8A5F"
                            android:textSize="11sp"
                            android:layout_marginTop="1dp"/>

                    </LinearLayout>

                    <!-- Artist -->
                    <LinearLayout
                        android:id="@+id/badgeArtist"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:background="@drawable/bg_badge_earned"
                        android:padding="14dp">

                        <FrameLayout
                            android:layout_width="38dp"
                            android:layout_height="38dp">
                            <ImageView
                                android:layout_width="38dp"
                                android:layout_height="38dp"
                                android:background="@drawable/bg_icon_chip"
                                android:contentDescription="@string/badge_icon_background3"/>
                            <TextView
                                android:layout_width="38dp"
                                android:layout_height="38dp"
                                android:text="@string/B"
                                android:textSize="18sp"
                                android:gravity="center"/>
                        </FrameLayout>

                        <TextView
                            android:id="@+id/tvArtistTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/ARt"
                            android:textColor="#1B5E20"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:layout_marginTop="10dp"/>

                        <TextView
                            android:id="@+id/tvArtistSubtitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/AW"
                            android:textColor="#5C8A5F"
                            android:textSize="11sp"
                            android:layout_marginTop="1dp"/>

                    </LinearLayout>

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:baselineAligned="false"
                    android:orientation="horizontal">

                    <!-- Current streak -->
                    <LinearLayout
                        android:id="@+id/badgeStreak"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:background="@drawable/bg_badge_earned"
                        android:padding="14dp"
                        android:layout_marginEnd="8dp">

                        <FrameLayout
                            android:layout_width="38dp"
                            android:layout_height="38dp">
                            <ImageView
                                android:layout_width="38dp"
                                android:layout_height="38dp"
                                android:background="@drawable/bg_icon_chip"
                                android:contentDescription="@string/badge_icon_background2"/>
                            <TextView
                                android:layout_width="38dp"
                                android:layout_height="38dp"
                                android:text="@string/FI"
                                android:textSize="18sp"
                                android:gravity="center"/>
                        </FrameLayout>

                        <TextView
                            android:id="@+id/tvStreakTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/_0_day_streak3"
                            android:textColor="#1B5E20"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:layout_marginTop="10dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/keep_going3"
                            android:textColor="#5C8A5F"
                            android:textSize="11sp"
                            android:layout_marginTop="1dp"/>

                    </LinearLayout>

                    <!-- 7-day streak goal, locks/unlocks -->
                    <LinearLayout
                        android:id="@+id/badgeSevenDay"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:background="@drawable/bg_badge_locked"
                        android:padding="14dp">

                        <FrameLayout
                            android:layout_width="38dp"
                            android:layout_height="38dp">
                            <ImageView
                                android:layout_width="38dp"
                                android:layout_height="38dp"
                                android:background="@drawable/bg_icon_chip"
                                android:contentDescription="@string/badge_icon_background"/>
                            <TextView
                                android:id="@+id/tvSevenDayIcon"
                                android:layout_width="38dp"
                                android:layout_height="38dp"
                                android:text="@string/LO"
                                android:textSize="18sp"
                                android:gravity="center"/>
                        </FrameLayout>

                        <TextView
                            android:id="@+id/tvSevenDayTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/_7_day_streak3"
                            android:textColor="#888888"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:layout_marginTop="10dp"/>

                        <TextView
                            android:id="@+id/tvSevenDaySubtitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/_7_more_days3"
                            android:textColor="#AAAAAA"
                            android:textSize="11sp"
                            android:layout_marginTop="1dp"/>

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

            <!-- Logout Button -->
            <LinearLayout
                android:id="@+id/btnLogout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/bg_logout_rounded"
                android:elevation="1dp"
                android:padding="16dp"
                android:gravity="center_vertical"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp">

                <TextView
                    android:layout_width="34dp"
                    android:layout_height="34dp"
                    android:text="@string/OUT"
                    android:textSize="18sp"
                    android:gravity="center"
                    android:background="@drawable/circle_red"
                    android:layout_marginEnd="10dp"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/log_out3"
                    android:textColor="#C62828"
                    android:textSize="14sp"
                    android:textStyle="bold"/>

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- Bottom Navigation -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:baselineAligned="false"
        android:orientation="horizontal"
        android:background="#FFFFFF">

        <LinearLayout android:id="@+id/navHome" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/HM" android:textSize="20sp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/home6" android:textColor="#A5D6A7" android:textSize="10sp"
                tools:ignore="SmallSp" />
        </LinearLayout>

        <LinearLayout android:id="@+id/navArt" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/DRAW" android:textSize="20sp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/ART1" android:textColor="#A5D6A7" android:textSize="10sp"
                tools:ignore="SmallSp" />
        </LinearLayout>

        <LinearLayout android:id="@+id/navProgress" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/PRO" android:textSize="20sp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/progress5" android:textColor="#A5D6A7" android:textSize="10sp"
                tools:ignore="SmallSp" />
        </LinearLayout>

        <LinearLayout android:id="@+id/navChat" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/CHAT1" android:textSize="20sp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/chat5" android:textColor="#A5D6A7" android:textSize="10sp"
                tools:ignore="SmallSp" />
        </LinearLayout>

        <LinearLayout android:id="@+id/navProfile" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:orientation="vertical" android:gravity="center" android:background="#F7F9F7">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/User" android:textSize="20sp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/profile5" android:textColor="#2E7D32" android:textSize="10sp" android:textStyle="bold"
                tools:ignore="SmallSp" />
        </LinearLayout>

    </LinearLayout>

</LinearLayout>