<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#E8F5E9">

    <!-- Top Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:orientation="horizontal"
        android:background="#2E7D32"
        android:gravity="center_vertical"
        android:padding="12dp">

        <TextView
            android:id="@+id/btnBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/back"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:layout_marginEnd="8dp"/>

        <ImageView
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:contentDescription="@string/todo5" android:src="@mipmap/ic_launcher_round"
            android:layout_marginEnd="10dp"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/healing_bot"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/online_always_here_for_you"
                android:textColor="#A5D6A7"
                android:textSize="11sp"/>

        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/dots"
            android:textColor="#FFFFFF"
            android:textSize="22sp"/>

    </LinearLayout>

    <!-- Chat Messages -->
    <ScrollView
        android:id="@+id/scrollChat"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="16dp">

        <LinearLayout
            android:id="@+id/chatContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- AI Message 1 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:contentDescription="@string/todo8"
                    android:src="@mipmap/ic_launcher_round"
                    android:layout_marginEnd="8dp"
                    android:layout_marginTop="4dp"/>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:maxWidth="260dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/healing_bot1"
                        android:textColor="#4CAF50"
                        android:textSize="11sp"
                        android:layout_marginBottom="4dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/hi_how_are_you_feeling_today_i_m_here_to_listen_and_support_you"
                        android:textColor="#1B5E20"
                        android:textSize="13sp"
                        android:background="@drawable/bubble_ai"
                        android:padding="12dp"/>

                </LinearLayout>

            </LinearLayout>

            <!-- User Message 1 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/i_have_been_experiencing_some_stress_lately"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:background="@drawable/bubble_user"
                    android:padding="12dp"
                    android:maxWidth="260dp"/>

            </LinearLayout>

            <!-- AI Message 2 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp"
                tools:ignore="UseCompoundDrawables">

                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:contentDescription="@string/todo6"
                    android:src="@mipmap/ic_launcher_round"
                    android:layout_marginEnd="8dp"
                    android:layout_marginTop="4dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/i_m_sorry_to_hear_that_stress_can_be_really_overwhelming_would_you_like_to_try_some_art_therapy_to_help_express_your_feelings"
                    android:textColor="#1B5E20"
                    android:textSize="13sp"
                    android:background="@drawable/bubble_ai"
                    android:padding="12dp"
                    android:maxWidth="260dp"/>

            </LinearLayout>

            <!-- Suggested Replies -->
            <LinearLayout
                style="?android:attr/buttonBarStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <Button
                    android:id="@+id/btnSaveCanvas"
                    style="?android:attr/buttonBarButtonStyle"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="@string/save_as_canvas"
                    android:textColor="#2E7D32"
                    android:backgroundTint="#FFFFFF"
                    android:textSize="11sp"
                    android:layout_marginEnd="8dp" />

                <Button
                    android:id="@+id/btnTryExercise"
                    style="?android:attr/buttonBarButtonStyle"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="@string/try_breathing_exercise"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#2E7D32"
                    android:textSize="11sp"/>

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- Message Input Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:orientation="horizontal"
        android:background="#FFFFFF"
        android:gravity="center_vertical"
        android:padding="8dp">

        <EditText
            android:id="@+id/etMessage"
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:layout_weight="1"
            android:autofillHints=""
            android:hint="@string/type_your_message"
            android:background="@drawable/input_background"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:textSize="13sp"
            android:inputType="textMultiLine"
            android:layout_marginEnd="8dp"/>

        <ImageView
            android:id="@+id/btnSend"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:contentDescription="@string/todo7"
            android:src="@android:drawable/ic_menu_send"
            android:background="@drawable/circle_dark_green"
            android:padding="10dp"/>

    </LinearLayout>

</LinearLayout>